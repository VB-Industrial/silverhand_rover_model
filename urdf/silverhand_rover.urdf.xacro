<?xml version="1.0"?>
<robot name="silverhand_rover" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===================== -->
  <!-- Общие параметры       -->
  <!-- ===================== -->

  <xacro:property name="PI" value="3.141592653589793"/>

  <!-- STL в миллиметрах -->
  <xacro:property name="mesh_scale" value="0.001 0.001 0.001"/>

  <!-- CAD-оси мешей отличаются от ROS:
       CAD: x - поперек, y - вверх, z - вперед
       ROS: x - вперед,  y - влево, z - вверх -->
  <xacro:property name="mesh_rpy" value="${PI/2} ${-PI/2} 0"/>
  <xacro:property name="show_body_mesh" value="false"/>
  <xacro:property name="show_differential_mesh" value="false"/>
  <xacro:property name="show_rocker_mesh" value="false"/>
  <xacro:property name="show_bogie_mesh" value="false"/>
  <xacro:property name="show_wheel_mesh" value="false"/>

  <!-- Геометрия для грубых collision -->
  <xacro:property name="body_size_x" value="0.92"/>
  <xacro:property name="body_size_y" value="0.60"/>
  <xacro:property name="body_size_z" value="0.32"/>

  <xacro:property name="wheel_radius" value="0.1269"/>
  <xacro:property name="wheel_width"  value="0.190"/>

  <!-- Массы пока очень грубые -->
  <xacro:property name="body_mass"         value="5.0"/>
  <xacro:property name="differential_mass" value="0.8"/>
  <xacro:property name="rocker_mass"       value="0.7"/>
  <xacro:property name="bogie_mass"        value="0.6"/>
  <xacro:property name="wheel_mass"        value="0.35"/>

  <!-- ===================== -->
  <!-- Параметры компоновки  -->
  <!-- ===================== -->

  <!-- Система координат:
       x - вперед
       y - влево
       z - вверх
  -->

  <!-- Высота base_link над землей.
       base_footprint лежит на земле, base_link находится выше. -->
  <xacro:property name="model_z_offset" value="0.350738"/>

  <!-- Положение рокера относительно base_link -->
  <xacro:property name="rocker_joint_x" value="0.10"/>
  <xacro:property name="rocker_joint_z" value="-0.10"/>
  <xacro:property name="left_rocker_joint_y"  value="0.355"/>
  <xacro:property name="right_rocker_joint_y" value="-0.355"/>

  <!-- Положение bogie относительно rocker -->
  <xacro:property name="bogie_joint_x" value="-0.25"/>
  <xacro:property name="bogie_joint_y" value="0.00"/>
  <xacro:property name="bogie_joint_z" value="0.00"/>

  <!-- Колесо 1: переднее, крепится к rocker -->
  <xacro:property name="front_wheel_x" value="0.30"/>
  <xacro:property name="front_wheel_y" value="0.00"/>
  <xacro:property name="front_wheel_z" value="-0.22"/>

  <!-- Колесо 2: среднее, крепится к bogie -->
  <xacro:property name="middle_wheel_x" value="0.02"/>
  <xacro:property name="middle_wheel_y" value="0.00"/>
  <xacro:property name="middle_wheel_z" value="-0.22"/>

  <!-- Колесо 3: заднее, крепится к bogie -->
  <xacro:property name="rear_wheel_x" value="-0.32"/>
  <xacro:property name="rear_wheel_y" value="0.00"/>
  <xacro:property name="rear_wheel_z" value="-0.22"/>

  <!-- Позиции бобышек корпуса под Leg -->
  <xacro:property name="leg_mount_x" value="0.053"/>
  <xacro:property name="leg_mount_z" value="-0.029"/>
  <xacro:property name="left_leg_mount_y" value="0.285"/>
  <xacro:property name="right_leg_mount_y" value="-0.285"/>

  <!-- ===================== -->
  <!-- Сдвиги STL внутри link -->
  <!-- ===================== -->
  <!-- Начни с нулей. Потом правь именно их,
       если сам mesh внутри link сидит криво. -->

  <xacro:property name="body_visual_xyz"         value="-0.017 0 -0.162"/>
  <xacro:property name="body_visual_rpy"         value="${PI/2} 0 ${PI/2}"/>

  <xacro:property name="differential_visual_xyz" value="0 0 0"/>
  <xacro:property name="differential_visual_rpy" value="${PI/2} 0 ${PI/2}"/>

  <xacro:property name="rocker_visual_xyz"       value="0 0 0"/>
  <xacro:property name="rocker_visual_rpy"       value="${PI/2} 0 ${3*PI/2}"/>

  <xacro:property name="bogie_visual_xyz"        value="0 0 -0.150"/>
  <xacro:property name="bogie_visual_rpy"        value="${PI/2} 0 ${PI/2}"/>

  <xacro:property name="left_front_wheel_visual_xyz"   value="-0.10706 -0.088 0.09654"/>
  <xacro:property name="right_front_wheel_visual_xyz"  value="-0.10706 0.088 0.09654"/>

  <xacro:property name="left_middle_wheel_visual_xyz"  value="0.10790 -0.088 0.09683"/>
  <xacro:property name="right_middle_wheel_visual_xyz" value="0.10790 0.088 0.09683"/>

  <xacro:property name="left_rear_wheel_visual_xyz"    value="0.14377 -0.088 0.09623"/>
  <xacro:property name="right_rear_wheel_visual_xyz"   value="0.14377 0.088 0.09623"/>

  <xacro:property name="left_front_wheel_visual_rpy"   value="${-PI/2} ${-0.890121786} 0"/>
  <xacro:property name="left_middle_wheel_visual_rpy"  value="${-PI/2} ${-0.928081215} 0"/>
  <xacro:property name="left_rear_wheel_visual_rpy"    value="${-PI/2} ${0.869224977} 0"/>

  <xacro:property name="right_front_wheel_visual_rpy"  value="${-PI/2} ${0.890121786} ${PI}"/>
  <xacro:property name="right_middle_wheel_visual_rpy" value="${-PI/2} ${0.928081215} ${PI}"/>
  <xacro:property name="right_rear_wheel_visual_rpy"   value="${-PI/2} ${-0.869224977} ${PI}"/>

  <!-- Если правая сторона окажется вывернутой,
       попробуй для правой стороны в visual поставить:
       0 ${PI} 0
       или
       0 0 ${PI}
  -->

  <!-- ===================== -->
  <!-- Материалы             -->
  <!-- ===================== -->

  <material name="gray">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <material name="dark">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>

  <!-- ===================== -->
  <!-- Макросы               -->
  <!-- ===================== -->

  <xacro:macro name="mesh_visual" params="filename xyz rpy material_name">
    <visual>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <geometry>
        <mesh filename="${filename}" scale="${mesh_scale}"/>
      </geometry>
      <material name="${material_name}"/>
    </visual>
  </xacro:macro>

  <xacro:macro name="mesh_collision" params="filename xyz rpy">
    <collision>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <geometry>
        <mesh filename="${filename}" scale="${mesh_scale}"/>
      </geometry>
    </collision>
  </xacro:macro>

  <xacro:macro name="box_visual" params="xyz rpy sx sy sz material_name">
    <visual>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <geometry>
        <box size="${sx} ${sy} ${sz}"/>
      </geometry>
      <material name="${material_name}"/>
    </visual>
  </xacro:macro>

  <xacro:macro name="cylinder_visual_y" params="xyz radius length material_name">
    <visual>
      <origin xyz="${xyz}" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${radius}" length="${length}"/>
      </geometry>
      <material name="${material_name}"/>
    </visual>
  </xacro:macro>

  <xacro:macro name="box_collision" params="xyz rpy sx sy sz">
    <collision>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <geometry>
        <box size="${sx} ${sy} ${sz}"/>
      </geometry>
    </collision>
  </xacro:macro>

  <xacro:macro name="cylinder_collision_y" params="xyz radius length">
    <collision>
      <origin xyz="${xyz}" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${radius}" length="${length}"/>
      </geometry>
    </collision>
  </xacro:macro>

  <xacro:macro name="inertial_box" params="mass sx sy sz">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (sy*sy + sz*sz) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * (sx*sx + sz*sz) / 12.0}"
        iyz="0.0"
        izz="${mass * (sx*sx + sy*sy) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertial_cylinder_y" params="mass radius length">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <!-- Цилиндр с осью вдоль Y -->
      <inertia
        ixx="${mass * (3*radius*radius + length*length) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${0.5 * mass * radius * radius}"
        iyz="0.0"
        izz="${mass * (3*radius*radius + length*length) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="wheel_link" params="name visual_xyz visual_rpy">
    <link name="${name}">
      <xacro:mesh_visual
        filename="package://silverhand_rover_model/meshes/Wheel.stl"
        xyz="${visual_xyz}"
        rpy="${visual_rpy}"
        material_name="dark"/>

      <xacro:mesh_collision
        filename="package://silverhand_rover_model/meshes/Wheel.stl"
        xyz="${visual_xyz}"
        rpy="${visual_rpy}"/>

      <xacro:inertial_cylinder_y
        mass="${wheel_mass}"
        radius="${wheel_radius}"
        length="${wheel_width}"/>
    </link>
  </xacro:macro>

  <!-- Одна сторона подвески:
       prefix = left / right
       side_y = + для левой стороны, - для правой
  -->
  <xacro:macro name="side_module" params="prefix side_y front_wheel_visual_xyz front_wheel_visual_rpy middle_wheel_visual_xyz middle_wheel_visual_rpy rear_wheel_visual_xyz rear_wheel_visual_rpy">

    <!-- ROCKER -->
    <link name="${prefix}_rocker_link">
      <xacro:inertial_box
        mass="${rocker_mass}"
        sx="0.40" sy="0.05" sz="0.16"/>
    </link>

    <joint name="base_to_${prefix}_rocker_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${prefix}_rocker_link"/>
      <origin xyz="${rocker_joint_x} ${side_y} ${rocker_joint_z}" rpy="0 0 0"/>
      <!-- Rocker качается в продольной плоскости -->
      <axis xyz="0 1 0"/>
      <limit lower="-1.2" upper="1.2" effort="50" velocity="2.0"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <!-- BOGIE -->
    <link name="${prefix}_bogie_link">
      <xacro:inertial_box
        mass="${bogie_mass}"
        sx="0.35" sy="0.05" sz="0.14"/>
    </link>

    <joint name="${prefix}_rocker_to_${prefix}_bogie_joint" type="revolute">
      <parent link="${prefix}_rocker_link"/>
      <child link="${prefix}_bogie_link"/>
      <origin xyz="${bogie_joint_x} ${bogie_joint_y} ${bogie_joint_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.2" upper="1.2" effort="50" velocity="2.0"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <!-- FRONT WHEEL -->
    <xacro:wheel_link
      name="${prefix}_front_wheel_link"
      visual_xyz="${front_wheel_visual_xyz}"
      visual_rpy="${front_wheel_visual_rpy}"/>

    <joint name="${prefix}_front_wheel_joint" type="continuous">
      <parent link="${prefix}_rocker_link"/>
      <child link="${prefix}_front_wheel_link"/>
      <origin xyz="${front_wheel_x} ${front_wheel_y} ${front_wheel_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>

    <!-- MIDDLE WHEEL -->
    <xacro:wheel_link
      name="${prefix}_middle_wheel_link"
      visual_xyz="${middle_wheel_visual_xyz}"
      visual_rpy="${middle_wheel_visual_rpy}"/>

    <joint name="${prefix}_middle_wheel_joint" type="continuous">
      <parent link="${prefix}_bogie_link"/>
      <child link="${prefix}_middle_wheel_link"/>
      <origin xyz="${middle_wheel_x} ${middle_wheel_y} ${middle_wheel_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>

    <!-- REAR WHEEL -->
    <xacro:wheel_link
      name="${prefix}_rear_wheel_link"
      visual_xyz="${rear_wheel_visual_xyz}"
      visual_rpy="${rear_wheel_visual_rpy}"/>

    <joint name="${prefix}_rear_wheel_joint" type="continuous">
      <parent link="${prefix}_bogie_link"/>
      <child link="${prefix}_rear_wheel_link"/>
      <origin xyz="${rear_wheel_x} ${rear_wheel_y} ${rear_wheel_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>

  </xacro:macro>

  <!-- ===================== -->
  <!-- База                  -->
  <!-- ===================== -->

  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${model_z_offset}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <xacro:mesh_visual
      filename="package://silverhand_rover_model/meshes/Body.stl"
      xyz="${body_visual_xyz}"
      rpy="${body_visual_rpy}"
      material_name="gray"/>

    <xacro:mesh_collision
      filename="package://silverhand_rover_model/meshes/Body.stl"
      xyz="${body_visual_xyz}"
      rpy="${body_visual_rpy}"/>

    <xacro:inertial_box
      mass="${body_mass}"
      sx="${body_size_x}" sy="${body_size_y}" sz="${body_size_z}"/>
  </link>

  <!-- Центральный visual-узел.
       Пока просто декоративно/визуально.
       Если потом захочешь честную механику дифференциала,
       его уже можно будет перестроить. -->
  <link name="differential_visual_link">
    <xacro:mesh_visual
      filename="package://silverhand_rover_model/meshes/Differential.stl"
      xyz="${differential_visual_xyz}"
      rpy="${differential_visual_rpy}"
      material_name="dark"/>

    <xacro:mesh_collision
      filename="package://silverhand_rover_model/meshes/Differential.stl"
      xyz="${differential_visual_xyz}"
      rpy="${differential_visual_rpy}"/>

    <xacro:inertial_box
      mass="${differential_mass}"
      sx="0.02" sy="0.28" sz="0.60"/>
  </link>

  <joint name="base_to_differential_visual_joint" type="fixed">
    <parent link="base_link"/>
    <child link="differential_visual_link"/>
    <origin xyz="-0.1769 0 0.111" rpy="0 0 0"/>
  </joint>

  <link name="left_leg_visual_link">
    <xacro:mesh_visual
      filename="package://silverhand_rover_model/meshes/Leg.stl"
      xyz="${rocker_visual_xyz}"
      rpy="${rocker_visual_rpy}"
      material_name="gray"/>

    <xacro:mesh_collision
      filename="package://silverhand_rover_model/meshes/Leg.stl"
      xyz="${rocker_visual_xyz}"
      rpy="${rocker_visual_rpy}"/>
  </link>

  <joint name="base_to_left_leg_visual_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_leg_visual_link"/>
    <origin xyz="${leg_mount_x} ${left_leg_mount_y} ${leg_mount_z}" rpy="0 0 0"/>
  </joint>

  <link name="right_leg_visual_link">
    <xacro:mesh_visual
      filename="package://silverhand_rover_model/meshes/Leg.stl"
      xyz="${rocker_visual_xyz}"
      rpy="${rocker_visual_rpy}"
      material_name="gray"/>

    <xacro:mesh_collision
      filename="package://silverhand_rover_model/meshes/Leg.stl"
      xyz="${rocker_visual_xyz}"
      rpy="${rocker_visual_rpy}"/>
  </link>

  <joint name="base_to_right_leg_visual_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_leg_visual_link"/>
    <origin xyz="${leg_mount_x} ${right_leg_mount_y} ${leg_mount_z}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== -->
  <!-- Левая и правая сторона -->
  <!-- ===================== -->

  <xacro:side_module
    prefix="left"
    side_y="${left_rocker_joint_y}"
    front_wheel_visual_xyz="${left_front_wheel_visual_xyz}"
    front_wheel_visual_rpy="${left_front_wheel_visual_rpy}"
    middle_wheel_visual_xyz="${left_middle_wheel_visual_xyz}"
    middle_wheel_visual_rpy="${left_middle_wheel_visual_rpy}"
    rear_wheel_visual_xyz="${left_rear_wheel_visual_xyz}"
    rear_wheel_visual_rpy="${left_rear_wheel_visual_rpy}"/>
  <xacro:side_module
    prefix="right"
    side_y="${right_rocker_joint_y}"
    front_wheel_visual_xyz="${right_front_wheel_visual_xyz}"
    front_wheel_visual_rpy="${right_front_wheel_visual_rpy}"
    middle_wheel_visual_xyz="${right_middle_wheel_visual_xyz}"
    middle_wheel_visual_rpy="${right_middle_wheel_visual_rpy}"
    rear_wheel_visual_xyz="${right_rear_wheel_visual_xyz}"
    rear_wheel_visual_rpy="${right_rear_wheel_visual_rpy}"/>

</robot>
